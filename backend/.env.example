# =============================================================================
# SPAS — Configuration d'environnement
# Copier ce fichier : cp .env.example .env
# Ne jamais committer .env dans git !
# =============================================================================

# -----------------------------------------------------------------------------
# Django
# -----------------------------------------------------------------------------
DEBUG=True
# Générer une clé secrète unique : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production

ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# Avec Docker : les valeurs ci-dessous correspondent à docker-compose.yml
# En local : adapter selon votre installation PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=spas_db
DB_USER=spas_user
DB_PASSWORD=spas_password
DB_HOST=localhost
DB_PORT=5432

# Pool de connexions (optionnel — 0 = pas de pool)
DB_CONN_MAX_AGE=600

# -----------------------------------------------------------------------------
# Redis — Cache et file de messages Celery
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# JWT — Durée de vie des tokens
# -----------------------------------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME=60        # minutes
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1   # jours

# -----------------------------------------------------------------------------
# CORS — Origines autorisées pour le frontend
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# Email (optionnel — console par défaut en développement)
# Pour Gmail : activer "Mot de passe d'application" dans votre compte Google
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@spas.com

# -----------------------------------------------------------------------------
# Machine Learning
# -----------------------------------------------------------------------------
ML_MODEL_PATH=ml_models/
ML_PREDICTION_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
DJANGO_LOG_LEVEL=INFO
